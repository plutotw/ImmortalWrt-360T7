# 基础架构与设备目标 (360T7 专属)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_mt7981-360-t7-108M=y

# 系统优化设置 (精简编译流程)
CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y
CONFIG_PKG_FORTIFY_SOURCE_2=y
# 移除不需要的内核 CGROUP 特性 (这些通常是 Docker 或高级限速才需要的)
# CONFIG_KERNEL_CGROUP_DEVICE is not set
# CONFIG_KERNEL_CGROUP_FREEZER is not set
# CONFIG_KERNEL_NET_CLS_CGROUP is not set

# 核心硬件加速与驱动 (360T7 性能核心)
CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_PACKAGE_kmod-mt_wifi=y
CONFIG_PACKAGE_kmod-warp=y
CONFIG_WARP_CHIPSET="mt7981"
CONFIG_WARP_VERSION=2
CONFIG_WED_HW_RRO_SUPPORT=y
CONFIG_PACKAGE_kmod-tcp-bbr=y

# 联发科闭源无线驱动配置 (高性能 Wi-Fi)
CONFIG_MTK_CHIP_MT7981=y
CONFIG_MTK_WIFI_DRIVER=y
CONFIG_MTK_DOT11_HE_AX=y
CONFIG_MTK_WPA3_SUPPORT=y
CONFIG_MTK_WARP_V2=y
CONFIG_MTK_WHNAT_SUPPORT=m
CONFIG_MTK_WIFI_MODE_AP=m

# 基础网络组件
CONFIG_PACKAGE_ip-bridge=y
CONFIG_PACKAGE_ip-tiny=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# 精简后的加密与库 (仅保留基础组件)
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_wget-ssl=y
# 如果不运行复杂脚本，其实 libcurl 也可以不选，这里保留以兼容部分 Luci 界面
CONFIG_PACKAGE_libcurl=y
# 禁用 libcurl 的冗余协议以减小体积
# CONFIG_LIBCURL_FTP is not set
# CONFIG_LIBCURL_TFTP is not set
# CONFIG_LIBCURL_COOKIES is not set

# 常用插件与界面 (保持纯净)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-turboacc-mtk=y
CONFIG_PACKAGE_luci-i18n-turboacc-mtk-zh-cn=y
CONFIG_PACKAGE_luci-app-mtk=y
CONFIG_PACKAGE_luci-i18n-mtk-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y

# 基础辅助工具
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_resolveip=y

# ZRAM 内存优化 (256MB 内存必备，提升稳定性)
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y

# --- 明确禁用的冗余项 ---
# 存储与文件系统 (360T7 无 USB)
# CONFIG_PACKAGE_kmod-ata-core is not set
# CONFIG_PACKAGE_kmod-scsi-core is not set
# CONFIG_PACKAGE_kmod-fs-vfat is not set
# CONFIG_PACKAGE_kmod-fs-autofs4 is not set
# CONFIG_PACKAGE_e2fsprogs is not set

# 插件与编辑器
# CONFIG_PACKAGE_luci-app-eqos is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_nano is not set
# CONFIG_PACKAGE_unzip is not set

# 网络抓包与高级测试
# CONFIG_PACKAGE_iperf3 is not set
# CONFIG_PACKAGE_tcpdump is not set